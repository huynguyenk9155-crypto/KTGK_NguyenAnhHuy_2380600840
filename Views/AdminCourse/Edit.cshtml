@model KTGK_LapTrinhWeb.Models.Course

@{
    ViewData["Title"] = "Chỉnh sửa học phần - Admin";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="border-bottom pb-3 mb-4">
                    <h2 class="fw-bold text-dark mb-1">Chỉnh sửa học phần</h2>
                    <p class="text-muted mb-0 small">Cập nhật các thông tin chi tiết cho học phần mã số #@Model.Id</p>
                </div>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small border-0 py-2 mb-3" role="alert"></div>
                    <input type="hidden" asp-for="Id" />
                    <!-- Lưu trữ đường dẫn ảnh cũ để tránh mất mát nếu người dùng không chọn ảnh mới -->
                    <input type="hidden" asp-for="Image" />

                    <div class="row g-3">
                        <!-- Name -->
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-bold text-muted small mb-1">Tên học phần</label>
                            <input asp-for="Name" class="form-control rounded-3" placeholder="Tên học phần" required />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Category -->
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-bold text-muted small mb-1">Thể loại danh mục</label>
                            <select asp-for="CategoryId" class="form-select rounded-3" asp-items="ViewBag.Categories" required></select>
                            <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Credits -->
                        <div class="col-md-3">
                            <label asp-for="Credits" class="form-label fw-bold text-muted small mb-1">Số tín chỉ</label>
                            <input asp-for="Credits" class="form-control rounded-3" type="number" min="1" max="10" placeholder="Số tín" required />
                            <span asp-validation-for="Credits" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Lecturer -->
                        <div class="col-md-3">
                            <label asp-for="Lecturer" class="form-label fw-bold text-muted small mb-1">Giảng viên giảng dạy</label>
                            <input asp-for="Lecturer" class="form-control rounded-3" placeholder="Tên giảng viên" required />
                            <span asp-validation-for="Lecturer" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Current Image Display -->
                        <div class="col-md-12 my-3">
                            <label class="form-label fw-bold text-muted small mb-2 d-block">Ảnh minh họa hiện tại</label>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(Model.Image))
                                {
                                    <img src="@Model.Image" class="rounded-3 object-fit-cover shadow-sm border" style="width: 120px; height: 90px;" alt="Ảnh hiện tại" onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
                                }
                                else
                                {
                                    <div class="rounded-3 bg-secondary text-white d-flex align-items-center justify-content-center shadow-sm border" style="width: 120px; height: 90px;">
                                        <i class="bi bi-book-half" style="font-size: 2rem;"></i>
                                    </div>
                                }
                                <div class="small text-muted">
                                    Đường dẫn: <code class="d-block mt-0.5 text-break">@Model.Image</code>
                                </div>
                            </div>
                        </div>

                        <!-- Image File Upload -->
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold text-muted small mb-1">Thay đổi hình ảnh học phần</label>
                            <div class="input-group">
                                <input type="file" name="imageFile" class="form-control rounded-3" id="imageFileInput" accept="image/*" />
                            </div>
                            <div class="form-text text-muted small mt-1">
                                Tải file hình ảnh mới lên nếu muốn thay thế ảnh hiện tại.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-3 fw-bold border-2">
                            Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 fw-bold shadow-sm">
                            <i class="bi bi-save-fill me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
