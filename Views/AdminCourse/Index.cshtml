@model IEnumerable<KTGK_LapTrinhWeb.Models.Course>

@{
    ViewData["Title"] = "Quản lý học phần - Admin";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 border-bottom pb-3 mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-1">Quản lý danh sách Học phần</h2>
                <p class="text-muted mb-0 small">Bảng điều khiển dành riêng cho Quản trị viên</p>
            </div>
            <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3 fw-bold shadow-sm align-self-start align-self-sm-center">
                <i class="bi bi-plus-circle-fill me-2"></i>Thêm học phần mới
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted uppercase font-monospace small">
                    <tr>
                        <th style="width: 100px;">Hình ảnh</th>
                        <th>Tên học phần</th>
                        <th>Thể loại</th>
                        <th>Giảng viên</th>
                        <th class="text-center" style="width: 100px;">Số tín chỉ</th>
                        <th class="text-center" style="width: 160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Image))
                                {
                                    <img src="@item.Image" class="rounded-3 object-fit-cover shadow-sm" style="width: 64px; height: 48px;" alt="@item.Name" onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
                                }
                                else
                                {
                                    <div class="rounded-3 bg-secondary text-white d-flex align-items-center justify-content-center shadow-sm" style="width: 64px; height: 48px;">
                                        <i class="bi bi-book-half" style="font-size: 1.2rem;"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td>
                                <span class="badge bg-info text-white rounded-pill px-2.5 py-1.5 small">
                                    @(item.Category?.Name ?? "N/A")
                                </span>
                            </td>
                            <td class="text-muted">@item.Lecturer</td>
                            <td class="text-center fw-bold text-dark">@item.Credits</td>
                            <td class="text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm rounded-3 px-3 py-1.5 fw-bold" title="Chỉnh sửa">
                                        <i class="bi bi-pencil-square me-1"></i>Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm rounded-3 px-3 py-1.5 fw-bold" title="Xóa">
                                        <i class="bi bi-trash-fill me-1"></i>Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
