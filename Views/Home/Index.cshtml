@model KTGK_LapTrinhWeb.Models.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ - Đăng ký học phần";
}

<!-- Hero Section -->
<div class="bg-gradient bg-primary text-white py-5 mb-5 rounded-4 shadow-sm relative overflow-hidden">
    <div class="container relative z-10 py-3">
        <div class="row align-items-center">
            <div class="col-lg-7 text-center text-lg-start">
                <h1 class="display-4 fw-bold mb-3">Hệ thống Đăng ký Học phần</h1>
                <p class="lead text-white-50 mb-0">Tìm kiếm và lựa chọn các khóa học phù hợp với chương trình đào tạo của bạn một cách nhanh chóng và dễ dàng.</p>
            </div>
            <div class="col-lg-5 mt-4 mt-lg-0">
                <!-- Search Box -->
                <div class="card border-0 shadow-lg rounded-3">
                    <div class="card-body p-3">
                        <form asp-controller="Home" asp-action="Index" method="get" class="d-flex gap-2">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 rounded-start-3 text-muted">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control border-start-0 rounded-end-0" placeholder="Nhập tên học phần cần tìm..." aria-label="Tìm kiếm học phần" />
                                <button type="submit" class="btn btn-primary rounded-end-3 px-4 fw-bold">Tìm kiếm</button>
                            </div>
                        </form>
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <div class="mt-2 text-start small">
                                <span class="text-muted">Kết quả tìm kiếm cho: </span>
                                <span class="fw-bold text-primary">"@Model.SearchTerm"</span>
                                <a asp-action="Index" class="text-danger ms-2 text-decoration-none"><i class="bi bi-x-circle-fill me-1"></i>Xóa lọc</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-2">
        <h2 class="fw-bold text-dark mb-0">Danh sách Học phần</h2>
        <span class="badge bg-secondary rounded-pill px-3 py-2">
            Tổng số học phần hiển thị: @Model.Courses.Count
        </span>
    </div>

    @if (!Model.Courses.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center my-5 bg-white">
            <div class="card-body">
                <div class="mb-4 text-muted">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-journal-x" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M6.1 1.1a.5.5 0 0 1 .1-.1H10a.5.5 0 0 1 .5.5v1.9a.5.5 0 0 1-.5.5H6.2a.5.5 0 0 1-.1-.1l-.1-.1V1.2a.5.5 0 0 1 .1-.1zM5 1.5v2A1.5 1.5 0 0 0 6.5 5h3A1.5 1.5 0 0 0 11 3.5v-2a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0-.5.5z"/>
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                    </svg>
                </div>
                <h4 class="fw-bold text-dark">Không tìm thấy học phần nào</h4>
                <p class="text-muted">Vui lòng thử lại với từ khóa khác hoặc quay lại danh sách đầy đủ.</p>
                <a asp-action="Index" class="btn btn-primary px-4 py-2 rounded-3 fw-bold mt-2">Xem tất cả học phần</a>
            </div>
        </div>
    }
    else
    {
        <!-- Courses Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
            @foreach (var course in Model.Courses)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden card-hover d-flex flex-column">
                        <!-- Course Image -->
                        <div class="position-relative overflow-hidden" style="height: 180px;">
                            @if (!string.IsNullOrEmpty(course.Image))
                            {
                                <img src="@course.Image" class="w-100 h-100 object-fit-cover" alt="@course.Name" onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
                            }
                            else
                            {
                                <div class="w-100 h-100 bg-gradient bg-secondary text-white d-flex align-items-center justify-content-center">
                                    <i class="bi bi-book-half" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <!-- Category Badge -->
                            <span class="position-absolute top-0 end-0 bg-info text-white m-3 px-3 py-1 rounded-pill small fw-bold shadow-sm">
                                @(course.Category?.Name ?? "Khác")
                            </span>
                        </div>

                        <!-- Course Info -->
                        <div class="card-body p-4 d-flex flex-column flex-grow-1">
                            <h5 class="card-title fw-bold text-dark mb-2 text-line-clamp-2" style="min-height: 48px;">
                                @course.Name
                            </h5>
                            
                            <div class="text-muted small mb-4 mt-auto">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-person-badge-fill text-primary me-2"></i>
                                    <span>Giảng viên: <strong class="text-dark">@course.Lecturer</strong></span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-journal-bookmark-fill text-success me-2"></i>
                                    <span>Số tín chỉ: <strong class="text-dark">@course.Credits</strong> tín chỉ</span>
                                </div>
                            </div>
                        </div>

                        <!-- Card Footer actions -->
                        <div class="card-footer bg-light p-3 border-0 border-top mt-auto d-flex justify-content-between align-items-center">
                            @if (User.IsInRole("ADMIN"))
                            {
                                <div class="w-100 d-flex gap-2">
                                    <a asp-controller="AdminCourse" asp-action="Edit" asp-route-id="@course.Id" class="btn btn-outline-warning btn-sm flex-grow-1 py-2 rounded-3 fw-bold">
                                        <i class="bi bi-pencil-square me-1"></i>Sửa
                                    </a>
                                    <a asp-controller="AdminCourse" asp-action="Delete" asp-route-id="@course.Id" class="btn btn-outline-danger btn-sm flex-grow-1 py-2 rounded-3 fw-bold">
                                        <i class="bi bi-trash-fill me-1"></i>Xóa
                                    </a>
                                </div>
                            }
                            else if (User.IsInRole("STUDENT"))
                            {
                                @if (Model.EnrolledCourseIds.Contains(course.Id))
                                {
                                    <form asp-controller="Enroll" asp-action="Unenroll" method="post" class="w-100">
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn btn-danger w-100 py-2 rounded-3 fw-bold d-flex align-items-center justify-content-center gap-1 shadow-sm">
                                            <i class="bi bi-x-circle-fill"></i> Hủy đăng ký
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Enroll" asp-action="Enroll" method="post" class="w-100">
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn btn-success w-100 py-2 rounded-3 fw-bold d-flex align-items-center justify-content-center gap-1 shadow-sm">
                                            <i class="bi bi-plus-circle-fill"></i> Đăng ký học phần
                                        </button>
                                    </form>
                                }
                            }
                            else
                            {
                                <!-- Guest User redirects to login -->
                                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString" class="btn btn-success w-100 py-2 rounded-3 fw-bold d-flex align-items-center justify-content-center gap-1 shadow-sm">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập để đăng ký
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination Controls -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Điều hướng trang" class="d-flex justify-content-center mt-5">
                <ul class="pagination pagination-md shadow-sm rounded-3">
                    <!-- Previous Page -->
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link py-2 px-3 border-0" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm" aria-label="Previous">
                            <span aria-hidden="true">&laquo; Trang trước</span>
                        </a>
                    </li>

                    <!-- Page Numbers -->
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link py-2 px-3 border-0" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm">@i</a>
                        </li>
                    }

                    <!-- Next Page -->
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link py-2 px-3 border-0" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm" aria-label="Next">
                            <span aria-hidden="true">Trang sau &raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
